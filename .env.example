# UrbanLens AI - Configuration Template
# Copy this file to '.env' and fill in your keys

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=urbanlens_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=urbanlens_ai

# Mapillary API Credentials (For street-level images)
# Get a token at: https://www.mapillary.com/developer
MAPILLARY_CLIENT_TOKEN=your_mapillary_client_token_here

# Reddit API Credentials (For social sentiment scraping)
# Register app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=UrbanLensAI/1.0 (contact: support@urbanlens.ai)

# OpenAQ API Key (For real-time air quality sensors)
OPENAQ_API_KEY=your_openaq_key_here

# Google Maps API Key (Optional fallback for street view)
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
